  "testing_instructions": {
    "how_to_use": [
      "1. Copy any payload from this file",
      "2. POST to /fraud_detection/detect-risk/ endpoint",
      "3. System will analyze and return risk_score + risk_label",
      "4. Compare against expected_risk_score and expected_label"
    ],
    "example_curl": "curl -X POST http://your-server/fraud_detection/detect-risk/ -H 'Content-Type: application/json' -d '{\"username\": \"testuser\", \"invoice_number\": \"INV-2026-001456\", ...}'",
    "fraud_detection_metrics": {
      "duplicate_detection": "Flags invoices with duplicate invoice_number in system",
      "amount_anomaly": "Detects amounts 2x+ higher than vendor average or 5x+ higher regardless",
      "bank_account_validation": "Checks account number format and validity",
      "ocr_confidence": "Flags documents with <65% OCR confidence",
      "vendor_risk": "Higher risk for new vendors or vendors with poor history",
      "payment_urgency": "Flags same-day due dates and urgent language",
      "compound_risk": "Combines multiple factors for accuracy"
    }
  }
