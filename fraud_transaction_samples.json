      "name": "Duplicate Invoice Attempt",
      "description": "Same invoice number submitted multiple times - classic duplicate payment fraud",
      "payload": {
        "username": "testuser",
        "invoice_id": 12345,
        "invoice_number": "INV-2026-001456",
        "vendor_name": "Premium Office Supplies Inc.",
        "total_amount": "1328.93",
        "currency": "USD",
        "invoice_date": "2026-03-06",
        "due_date": "2026-03-20",
        "bank_account": "987654321098",
        "ocr_confidence": 0.95
      },
      "expected_risk_score": 0.85,
      "expected_label": "high",
      "fraud_indicators": [
        "Exact duplicate of legitimate invoice",
        "Same vendor, amount, and date",
        "Attempt to process payment twice"
      ]
