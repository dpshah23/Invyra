# Copy this file to .env and fill in your own values.
# PostgreSQL (Aiven) credentials
DB_ENGINE="django.db.backends.postgresql"
DB_NAME=""
DB_USER=""
DB_PASSWORD=""
DB_HOST=""
DB_PORT="5432"
DB_SSLMODE="require"

# Optional aliases commonly provided by cloud Postgres providers
# PGDATABASE=""
# PGUSER=""
# PGPASSWORD=""
# PGHOST=""
# PGPORT="5432"

PK_KEY="your_stripe_publishable_key"
SK_KEY="your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"
DOMAIN="http://127.0.0.1:8000"
STRIPE_PAYMENT_METHOD_TYPES="card"
